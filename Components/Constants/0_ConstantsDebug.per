; DEBUG CONSTANTS: 1 TO 30
; Set to 1 to enable debug messages for that topic, 0 to disable

; ECONOMY - 1 TO 5
(defconst debugVillagersPercent 1)
(defconst debugFarming 2)
(defconst debugWood 3)
(defconst debugMining 4)
(defconst debugFishing 5)

; INITIALIZATION - ALL OFF BY DEFAULT
(defrule
  (true)
=>
  (set-goal debugVillagersPercent 1)
  (set-goal debugFarming 0)
  (set-goal debugWood 0)
  (set-goal debugMining 0)
  (set-goal debugFishing 0)
  (disable-self)
)
