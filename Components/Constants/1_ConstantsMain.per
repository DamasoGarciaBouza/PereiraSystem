(defrule
  (population-cap >= 150)
=>
  (set-goal minArmySize 59)
  (set-goal maxArmySize 60)
  (disable-self)
)

(defrule
  (population-cap >= 125)
=>
  (set-goal minArmySize 49)
  (set-goal maxArmySize 50)
  (disable-self)
