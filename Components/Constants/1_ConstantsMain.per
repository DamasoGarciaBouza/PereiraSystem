; MAIN CONSTANTS: 31 TO 80

(defconst randomNumber 31)

(defconst weMovedPlace 32) ;for experimental move to the coast tactic
(defconst weHaveTownCenterAndWoodForLC 33)
(defconst weHaveBarracksAndSomeVillagers 34)
(defconst weHaveArcheryOrStableAndSomeSoldiers 35)

(defconst populationRoomBeforeBuildingHouses 36)
(defconst lumberCampDistanceIncrement 37)
(defconst miningCampDistanceIncrement 38)

(defconst avoidBuildingDocks 40)
(defconst avoidCreatingNavy 41)
(defconst weStoppedLumberjacks 42)

(defconst secondsUntilFirstAttack 50)
(defconst minutesUntilFirstAttack 51) ; for info only
(defconst weAreAttacking 52)
(defconst minArmySize 54)
(defconst maxArmySize 55)
(defconst numberAttackGroups 56)

(defconst deletingBarracks 60)
(defconst deletingStable 61)
(defconst deletingArchery 62)
(defconst deletingSiege 63)

(defconst civilianMessages 79)
(defconst militaryMessages 80)

; INITIALIZATION
(defrule
  (true)
=>
  (set-goal deletingBarracks 0)
  (set-goal deletingStable 0)
  (set-goal deletingArchery 0)
  (set-goal deletingSiege 0)
  (set-goal weAreAttacking 0)
  (disable-self)
)

(defrule
  (population-cap <= 250)
=>
  (set-goal lumberCampDistanceIncrement 1)
  (set-goal miningCampDistanceIncrement 4)
  (disable-self)
)

(defrule
  (population-cap > 250)
=>
  (set-goal lumberCampDistanceIncrement 2)
  (set-goal miningCampDistanceIncrement 8)
  (disable-self)
)

(defrule
  (population-cap > 400)
=>
  (set-goal lumberCampDistanceIncrement 4)
  (set-goal miningCampDistanceIncrement 16)
  (disable-self)
)

; AVOID DOCKS - 40
(defrule
  (or
    (or
      (or(map-type acropolis)(map-type arabia))
      (or(map-type atacama)(map-type baltic))
    )
    (or
      (or(map-type black-forest)(map-type bog-islands))
      (or(map-type budapest)(map-type cenotes))
    )
  )
=>
  (set-goal avoidBuildingDocks 1)
  (disable-self)
)

(defrule
  (or
    (or
      (or(map-type coastal)(map-type coastal-forest))
      (or(map-type crater-lake)(map-type crossroads))
    )
    (or
      (or(map-type black-forest)(map-type bog-islands))
      (or(map-type budapest)(map-type cenotes))
    )
  )
=>
  (set-goal avoidBuildingDocks 1)
  (disable-self)
)

; POPULATION ROOM BEFORE BUILDING HOUSES
(defrule
  (true)
=>
  (set-goal populationRoomBeforeBuildingHouses 3)
  (disable-self)
)

(defrule
  (current-age == feudal-age)
=>
  (set-goal populationRoomBeforeBuildingHouses 6)
  (disable-self)
)

(defrule
  (current-age == castle-age)
=>
  (set-goal populationRoomBeforeBuildingHouses 9)
  (disable-self)
)

(defrule
  (current-age == imperial-age)
=>
  (set-goal populationRoomBeforeBuildingHouses 14)
  (disable-self)
)

; MIN/MAX ARMY SIZE - usando >= en orden descendente para cubrir cualquier pop cap
(defrule
  (population-cap >= 500)
=>
  (set-goal minArmySize 199)
  (set-goal maxArmySize 200)
  (disable-self)
)

(defrule
  (population-cap >= 450)
=>
  (set-goal minArmySize 179)
  (set-goal maxArmySize 180)
  (disable-self)
)

(defrule
