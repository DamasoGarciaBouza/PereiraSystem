; DETECTING - PEREIRA SYSTEM AI
; ============================================================

; ============================================================
; CAVALRY
; ============================================================

(defrule
    (or
        (or
            (or
                (players-unit-type-count any-enemy scout-cavalry-line > 2)
                (players-unit-type-count any-enemy knight-line > 2)
            )
            (or
                (players-unit-type-count any-enemy steppe-lancer-line > 2)
                (players-unit-type-count any-enemy tarkan-set > 2)
            )
        )
        (or
            (or
                (players-unit-type-count any-enemy konnik-set > 2)
                (players-unit-type-count any-enemy leitis-line > 2)
            )
            (or
                (players-unit-type-count any-enemy coustillier-line > 2)
                (players-unit-type-count any-enemy tarkan-line > 2)
            )
        )
    )
=>
    (set-goal dudeHasCavalry 1)
)

(defrule
    (or
        (or
            (or
                (players-unit-type-count any-enemy magyar-huszar-line > 2)
                (players-unit-type-count any-enemy arambai-line > 2)
            )
            (or
                (players-unit-type-count any-enemy cataphract-line > 2)
                (players-unit-type-count any-enemy war-wagon-line > 2)
            )
        )
        (or
            (or
                (players-unit-type-count any-enemy conquistador-line > 2)
                (players-unit-type-count any-enemy mangudai-line > 2)
            )
            (or
                (players-unit-type-count any-enemy mameluke-line > 2)
                (players-unit-type-count any-enemy boyar-line > 2)
            )
        )
    )
=>
    (set-goal dudeHasCavalry 1)
)

(defrule
    (players-unit-type-count every-enemy scout-cavalry-line < 2)
    (players-unit-type-count every-enemy knight-line < 2)
    (players-unit-type-count every-enemy steppe-lancer-line < 2)
    (players-unit-type-count every-enemy tarkan-set < 2)
    (players-unit-type-count every-enemy konnik-set < 2)
    (players-unit-type-count every-enemy leitis-line < 2)
    (players-unit-type-count every-enemy coustillier-line < 2)
    (players-unit-type-count every-enemy tarkan-line < 2)
    (players-unit-type-count every-enemy magyar-huszar-line < 2)
    (players-unit-type-count every-enemy arambai-line < 2)
    (players-unit-type-count every-enemy cataphract-line < 2)
    (players-unit-type-count every-enemy war-wagon-line < 2)
    (players-unit-type-count every-enemy conquistador-line < 2)
    (players-unit-type-count every-enemy mangudai-line < 2)
    (players-unit-type-count every-enemy mameluke-line < 2)
    (players-unit-type-count every-enemy boyar-line < 2)
=>
    (set-goal dudeHasCavalry 0)
)


