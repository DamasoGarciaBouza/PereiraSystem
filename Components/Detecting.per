; ELEPHANTS
; ============================================================

(defrule
    (players-unit-type-count any-enemy battle-elephant-line > 0)
=>
    (set-goal dudeHasElephants 1)
)

(defrule
    (players-unit-type-count every-enemy battle-elephant-line == 0)
=>
    (set-goal dudeHasElephants 0)
)


