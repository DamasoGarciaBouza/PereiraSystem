; ============================================================
; SIEGE WEAPONS
; ============================================================

(defrule
    (or
        (or
            (players-unit-type-count any-enemy mangonel-line > 0)
            (players-unit-type-count any-enemy scorpion-line > 0)
        )
        (or
            (players-unit-type-count any-enemy battering-ram-line > 0)
            (players-unit-type-count any-enemy bombard-cannon-line > 0)
        )
    )
=>
    (set-goal dudeHasSiegeWeapons 1)
)

(defrule
    (players-unit-type-count every-enemy mangonel-line == 0)
    (players-unit-type-count every-enemy scorpion-line == 0)
    (players-unit-type-count every-enemy battering-ram-line == 0)
    (players-unit-type-count every-enemy bombard-cannon-line == 0)
=>
    (set-goal dudeHasSiegeWeapons 0)
)


