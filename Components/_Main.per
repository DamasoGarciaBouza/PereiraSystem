; PEREIRA SYSTEM AI - AGE OF EMPIRES II DEFINITIVE

;ROUTES MUST BE ABSOLUTE, NOT RELATIVE TO THIS FILE!!!!

; CONSTANTS - 7 FILES
(load "PereiraSystem/Components/Constants/1_ConstantsDebug");1 to 30
(load "PereiraSystem/Components/Constants/1_ConstantsMain");1 to 50
(load "PereiraSystem/Components/Constants/2_ConstantsCivCharacteristics");50 to 70
(load "PereiraSystem/Components/Constants/3_ConstantsFacts");70 to 120
(load "PereiraSystem/Components/Constants/4_ConstantsBuilding");120 to 170
(load "PereiraSystem/Components/Constants/5_ConstantsCosts");300 to 350
(load "PereiraSystem/Components/Constants/6_ConstantsDetecting");350 to 380
(load "PereiraSystem/Components/Constants/7_ConstantsTraining");380 to 512

; STRATEGIC NUMBERS - 2 FILES
(load "PereiraSystem/Components/StrategicNumbers/Civilian_SN")
(load "PereiraSystem/Components/StrategicNumbers/Exploring_SN")
(load "PereiraSystem/Components/StrategicNumbers/Military_SN")

; GAME VARIABLES (MAP TYPE, DIFFICULTY - (MAP SIZE IN BUILDING WALL SECTION))
(load "PereiraSystem/Components/GameVariables/Difficulty")

; BUILDING ACTIONS - 2 FILES
(load "PereiraSystem/Components/Building/BuildingMain")
(load "PereiraSystem/Components/Building/BuildingWall")

; OTHER IMPORTANT ACTIONS - 4 FILES
(load "PereiraSystem/Components/Detecting")
(load "PereiraSystem/Components/Training")
(load "PereiraSystem/Components/Researching")
(load "PereiraSystem/Components/Trade")


; TIMERS -2 FILES
(load "PereiraSystem/Components/Timers/Timers_civilian")
(load "PereiraSystem/Components/Timers/Timers_military")

; OTHER - 3 FILES
; PLAYER NAMES, TAUNTS
(load "PereiraSystem/Components/PlayerNames")
(load "PereiraSystem/Components/TauntsA_Emission")
(load "PereiraSystem/Components/TauntsB_Response")
(load "PereiraSystem/Components/Testing")


; I use the cheat for making things faster sometimes
(defrule (true)
    (cheats-enabled)
=>
    (up-cc-send-cheat "AEGIS")
    (disable-self)
)


